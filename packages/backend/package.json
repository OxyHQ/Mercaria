{
  "name": "@mercaria/backend",
  "version": "1.0.0",
  "description": "Mercaria API — buy/sell marketplace backend by Oxy",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mercaria/shared-types": "workspace:*",
    "@oxyhq/core": "^12.4.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.80.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.7",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.22.2",
    "ioredis": "^5.11.1",
    "mongoose": "^9.7.4",
    "pino": "^10.3.1",
    "rate-limit-redis": "^5.0.0",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.15.43",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.5",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
