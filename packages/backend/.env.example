# ================================
# DATABASE
# ================================
# MongoDB connection string. The database name is derived as
# `mercaria-{NODE_ENV}` and passed to mongoose.connect() — do NOT embed it
# in the URI.
# Local:  mongodb://localhost:27017
# Remote: mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017

# Optional CA cert (PEM) for TLS connections to managed MongoDB.
# CA_CERT=

# ================================
# API SERVER
# ================================
# Port the API listens on.
PORT=3001

# Web app origin (for CORS).
WEB_URL=http://localhost:3000

# ================================
# OXY AUTH
# ================================
# Base URL of the Oxy API used to validate sessions/service tokens.
OXY_API_URL=https://api.oxy.so

# Optional internal service secret (server-to-server calls). Generate with:
#   openssl rand -hex 32
# SERVICE_SECRET=

# Optional secret for the trusted internal bot auth helper. Generate with:
#   openssl rand -hex 32
# TELEGRAM_BOT_SECRET=

# ================================
# CONNECTORS (external platform sync)
# ================================
# AES-256-GCM key used to encrypt external-platform credentials at rest (Shopify
# OAuth tokens, WooCommerce keys, …). REQUIRED once a connector is configured;
# the crypto helper fails closed with a clear error if it is missing or malformed
# when a credential is encrypted/decrypted. Must be a 64-character hex string
# (32 bytes). Generate with:
#   openssl rand -hex 32
# CONNECTOR_ENCRYPTION_KEY=

# HMAC secret used to sign/verify the OAuth `state` CSRF token exchanged during a
# connect flow. REQUIRED to start a connect. Generate with:
#   openssl rand -hex 32
# CONNECTOR_OAUTH_STATE_SECRET=

# Public base URL of THIS backend — used to build the OAuth callback the external
# platform redirects to (`{base}/channels/oauth/{provider}/callback`). This exact
# callback URL must be registered in the platform's app settings (deploy handoff).
# CONNECTOR_OAUTH_REDIRECT_BASE_URL=https://api.mercaria.co

# Where to send the merchant's browser after a successful connect (the dashboard's
# channels screen). Optional — when unset the callback shows a plain success page.
# CONNECTOR_OAUTH_SUCCESS_REDIRECT_URL=https://dashboard.mercaria.co/channels

# Mercaria category slug that pulled products are filed under (Fase 1). Must be an
# existing category slug (see the seed). Per-connection category mapping is Fase 2.
# CONNECTOR_DEFAULT_CATEGORY_SLUG=home

# --- Shopify Partner app (deploy handoff — register the app to get these) ---
# App API key (client id) and secret from the Shopify Partner dashboard.
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# OAuth scopes to request (comma/space separated). Defaults to `read_products`.
# SHOPIFY_SCOPES=read_products

# ================================
# REDIS (optional)
# ================================
# Enables the Redis-backed rate-limit store and Socket.IO scaling. Without it,
# the app falls back to in-memory (per-instance) behavior.
# Local:   redis://localhost:6379
# Managed: rediss://user:password@host:port
# REDIS_URL=

# Optional CA cert (PEM) for TLS connections to managed Redis.
# REDIS_CA_CERT=

# ================================
# WEB PUSH (optional)
# ================================
# VAPID keys for browser push notifications. Generate with:
#   bunx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@mercaria.co

# ================================
# LOGGING
# ================================
# LOG_LEVEL=info

# ================================
# NOTES
# ================================
# - Copy this file to .env and fill in your values.
# - Never commit .env to version control.
