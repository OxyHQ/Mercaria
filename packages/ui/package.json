    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo-blur": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "lucide-react-native": "^0.562.0",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.3",
