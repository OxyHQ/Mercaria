{
  "name": "mercaria-dashboard",
  "compatibility_date": "2026-06-30",
  "main": "./dist/_worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "workers_dev": false,
  "preview_urls": false
}
